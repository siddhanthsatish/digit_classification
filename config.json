{
  "splits_dir": "data/splits",
  "num_classes": 11,
  "data_dir": "data",
  "ckpt_dir": "outputs/checkpoints",
  "bg_crops_dir": "data/bg_crops",
  "results_dir": "outputs/results",

  "custom": {
    "epochs": 30,
    "batch_size": 128,
    "lr": 1e-3,
    "weight_decay": 1e-4,
    "patience": 7,
    "scheduler_patience": 3,
    "scheduler_factor": 0.5,
    "dropout_conv": 0.25,
    "dropout_fc": 0.5,
    "filters": [32, 64, 128],
    "fc_hidden": 512
  },

  "vgg16": {
    "epochs": 20,
    "batch_size": 64,
    "lr": 1e-4,
    "backbone_lr_scale": 0.1,
    "weight_decay": 1e-4,
    "patience": 7,
    "scheduler_patience": 3,
    "scheduler_factor": 0.5,
    "freeze_features": false
  },

  "dataset": {
    "val_split": 0.05,
    "seed": 42,
    "num_workers": 8,
    "image_size": 32,
    "mean": [0.4377, 0.4438, 0.4728],
    "std": [0.1980, 0.2010, 0.1970],
    "bg_ratio": 1.0,
    "bg_iou_threshold": 0.3,
    "bg_max_per_image": 10,
    "augment_degrees": 15,
    "augment_translate": [0.1, 0.1],
    "augment_scale": [0.9, 1.1],
    "color_jitter_brightness": 0.3,
    "color_jitter_contrast": 0.3,
    "color_jitter_saturation": 0.2
  },

  "inference": {
    "conf_threshold": 0.85,
    "nms_iou": 0.3,
    "max_boxes": 5,
    "nn_threshold": null,
    "batch_size": 64,
    "use_mser": true,
    "use_sliding": false,
    "win_size": 32,
    "sliding_step": 24,
    "pyramid_scale": 0.9,
    "mser_min_area": 50,
    "mser_max_area": 3000,
    "mser_min_aspect": 0.2,
    "mser_max_aspect": 5.0
  }
}
